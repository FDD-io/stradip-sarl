---
import AdminLayout from '../../layouts/AdminLayout.astro';

// Récupération des données réelles depuis l'API FastAPI
const productsRes = await fetch(`${import.meta.env.PUBLIC_API_URL}/api/products/`);
const pData = await productsRes.json();
const products = pData.items || pData;

const projectsRes = await fetch(`${import.meta.env.PUBLIC_API_URL}/api/projects/`);
const prData = await projectsRes.json();
const projects = prData.items || prData;

const accessoriesRes = await fetch(`${import.meta.env.PUBLIC_API_URL}/api/accessories/`);
const accData = await accessoriesRes.json();
const accessories = accData.items || accData;

// Récupération des activités réelles
const activitiesResponse = await fetch(`${import.meta.env.PUBLIC_API_URL}/api/activities/?limit=5`);
const actData = await activitiesResponse.json();
const activities = actData.items || actData;

const stats = [
    { label: 'Catalogue Carreaux', value: (products.length || 0).toString(), icon: '📦', color: 'text-stradip-blue' },
    { label: 'Projets Réalisés', value: (projects.length || 0).toString(), icon: '🏗️', color: 'text-stradip-cyan' },
    { label: 'Boutique Technique', value: (accessories.length || 0).toString(), icon: '🛠️', color: 'text-emerald-500' },
];

const quickActions = [
    { name: 'Nouveau Carreau', href: '/admin/produits/add', icon: '✨', desc: 'Ajouter une référence au catalogue' },
    { name: 'Nouvelle Réalisation', href: '/admin/projets/add', icon: '📸', desc: 'Exposer un nouveau chantier' },
    { name: 'Boutique Technique', href: '/admin/accessoires', icon: '🛠️', desc: 'Gérer les colles et outillages' },
    { name: 'Paramètres', href: '#', icon: '⚙️', desc: 'Configuration du compte' },
];
---

<AdminLayout title="Tableau de bord">
    <header class="flex flex-col sm:flex-row justify-between items-start sm:items-center gap-6 mb-12">
        <div>
            <h2 class="text-3xl font-black text-slate-900 uppercase tracking-tighter">Console de Gestion</h2>
            <p class="text-slate-500 text-sm mt-1">Bienvenue sur votre espace STRADIP Admin.</p>
        </div>
        <div class="text-right hidden sm:block">
            <p class="text-[10px] font-black uppercase tracking-[3px] text-slate-400" id="current-date"></p>
        </div>
    </header>

    <!-- STATS GRID -->
    <div class="grid grid-cols-1 md:grid-cols-3 gap-6 md:gap-8 mb-12 md:mb-16">
        {stats.map(stat => (
            <div class="bg-white p-6 sm:p-8 rounded-3xl shadow-sm border border-slate-100 hover:shadow-xl transition-all duration-500 group">
                <div class="flex justify-between items-start mb-4">
                    <span class="text-3xl group-hover:scale-110 transition-transform duration-500">{stat.icon}</span>
                    <span class={`text-[10px] font-black uppercase tracking-widest ${stat.color}`}>STRADIP Insights</span>
                </div>
                <h3 class="text-4xl font-black text-slate-900 mb-1">{stat.value}</h3>
                <p class="text-xs font-bold text-slate-400 uppercase tracking-wider">{stat.label}</p>
            </div>
        ))}
    </div>

    <!-- QUICK ACTIONS -->
    <div class="bg-white rounded-3xl border border-slate-100 shadow-sm overflow-hidden">
        <div class="p-6 sm:p-8 border-b border-slate-50">
            <h3 class="font-black text-slate-900 uppercase text-xs tracking-[3px]">Actions Prioritaires</h3>
        </div>
        <div class="p-6 sm:p-8 grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-6">
            {quickActions.map(action => (
                <a href={action.href} class="flex flex-col p-6 bg-slate-50 rounded-2xl border border-transparent hover:border-stradip-cyan hover:bg-white hover:shadow-2xl transition-all duration-500 group">
                    <span class="text-3xl mb-4 group-hover:rotate-12 transition-transform">{action.icon}</span>
                    <span class="text-xs font-black uppercase tracking-widest text-slate-900 mb-1">{action.name}</span>
                    <span class="text-[10px] text-slate-400 font-medium">{action.desc}</span>
                </a>
            ))}
        </div>
    </div>

    <!-- RECENT ACTIVITY -->
    <div class="mt-16">
        <div class="flex items-center gap-6 mb-8">
            <h3 class="text-xl font-black uppercase tracking-tighter text-slate-900">Dernières Activités</h3>
            <div class="flex-grow h-px bg-slate-100"></div>
        </div>
        <div class="space-y-4">
            {activities.map((act: any) => (
                <div class="bg-white p-5 sm:p-6 rounded-2xl border border-slate-100 flex flex-col sm:flex-row sm:items-center justify-between gap-4 group hover:border-stradip-cyan/30 transition-all">
                    <div class="flex items-center gap-4">
                        <div class="w-10 h-10 bg-slate-50 rounded-xl flex items-center justify-center text-lg group-hover:scale-110 transition-transform">
                            {act.icon}
                        </div>
                        <div>
                            <p class="text-sm font-bold text-slate-800 tracking-tight">
                                {act.action} du {act.target_type.toLowerCase()} <span class="text-stradip-blue">"{act.target_name}"</span>
                            </p>
                            <p class="text-[10px] text-slate-400 uppercase font-bold tracking-widest mt-0.5">
                                {new Date(act.timestamp).toLocaleString('fr-FR', { day: '2-digit', month: 'short', hour: '2-digit', minute: '2-digit' })}
                            </p>
                        </div>
                    </div>
                    <span class="self-start sm:self-center px-3 py-1 bg-slate-50 text-slate-400 text-[9px] font-black uppercase tracking-widest rounded-full group-hover:bg-stradip-cyan/10 group-hover:text-stradip-cyan transition-colors">Admin</span>
                </div>
            ))}

            {activities.length === 0 && (
                <div class="bg-white p-12 rounded-2xl border border-dashed border-slate-200 text-center">
                    <p class="text-slate-400 text-sm italic font-medium">Aucune activité récente enregistrée.</p>
                </div>
            )}
        </div>
    </div>
</AdminLayout>

<script>
    const dateEl = document.getElementById('current-date');
    if (dateEl) {
        const now = new Date();
        const options: Intl.DateTimeFormatOptions = { day: '2-digit', month: 'long', year: 'numeric' };
        dateEl.textContent = now.toLocaleDateString('fr-FR', options);
    }
</script>
