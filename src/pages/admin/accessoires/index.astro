---
import AdminLayout from '../../../layouts/AdminLayout.astro';

// Récupération des accessoires depuis l'API FastAPI
let accessories = [];
try {
    const response = await fetch(`${import.meta.env.PUBLIC_API_URL}/api/accessories/`);
    if (response.ok) {
        const data = await response.json();
        const rawAccessories = data.items || data;
        
        if (Array.isArray(rawAccessories)) {
            // Tri par ID décroissant pour la stabilité
            accessories = rawAccessories.sort((a, b) => b.id - a.id).map((acc: any) => ({
                id: acc.id,
                nom: acc.nom,
                categorie: acc.categorie_acc,
                image: acc.image_url.startsWith('http') ? acc.image_url : `${import.meta.env.PUBLIC_API_URL}${acc.image_url}`
            }));
        }
    }
} catch (e) {
    console.error("Erreur de chargement des accessoires", e);
}
---

<AdminLayout title="Gestion des Accessoires">
    <div class="flex flex-col md:flex-row justify-between items-start md:items-end gap-6 mb-12">
        <div>
            <h2 class="text-3xl font-black text-slate-900 uppercase tracking-tighter italic">Boutique <span class="text-stradip-cyan">Technique</span></h2>
            <p class="text-slate-500 text-sm mt-1">Gérez les colles, joints et outillages professionnels.</p>
        </div>

        <div class="flex flex-wrap items-center gap-4 sm:gap-6 w-full md:w-auto justify-between md:justify-end">
            <span class="text-[10px] font-black uppercase tracking-widest text-slate-400">
                {accessories.length} Articles en stock
            </span>
            <a href="/admin/accessoires/ajouter" class="bg-[#0a1628] text-white px-6 sm:px-8 py-3.5 sm:py-4 rounded-xl sm:rounded-2xl text-[10px] font-black uppercase tracking-[2px] hover:bg-stradip-cyan transition-all duration-500 shadow-xl shadow-blue-900/10">
                + Ajouter un accessoire
            </a>
        </div>
    </div>

    <div class="bg-white rounded-[2.5rem] border border-slate-100 shadow-sm overflow-hidden">
        <div class="overflow-x-auto">
            <table class="w-full text-left border-collapse min-w-[600px]">
                <thead>
                    <tr class="bg-slate-50/50">
                        <th class="p-8 text-[10px] font-black uppercase tracking-widest text-slate-400 border-b border-slate-50">Aperçu</th>
                        <th class="p-8 text-[10px] font-black uppercase tracking-widest text-slate-400 border-b border-slate-50">Désignation</th>
                        <th class="p-8 text-[10px] font-black uppercase tracking-widest text-slate-400 border-b border-slate-50">Catégorie</th>
                        <th class="p-8 text-[10px] font-black uppercase tracking-widest text-slate-400 border-b border-slate-50 text-right">Actions</th>
                    </tr>
                </thead>
                <tbody class="divide-y divide-slate-50">
                    {accessories.map(acc => (
                        <tr class="hover:bg-slate-50/50 transition-colors group">
                            <td class="p-8">
                                <div class="w-16 h-16 bg-slate-100 rounded-2xl overflow-hidden shadow-sm group-hover:scale-110 transition-transform duration-500">
                                    <img src={acc.image} class="w-full h-full object-cover" />
                                </div>
                            </td>
                            <td class="p-8">
                                <p class="text-sm font-black text-slate-900 uppercase tracking-tight">{acc.nom}</p>
                                <p class="text-[9px] text-slate-400 uppercase font-bold tracking-widest mt-1 italic">REF: ACC-00{acc.id}</p>
                            </td>
                            <td class="p-8">
                                <span class="px-4 py-1.5 bg-slate-100 text-slate-500 text-[9px] font-black uppercase tracking-widest rounded-full group-hover:bg-stradip-cyan/10 group-hover:text-stradip-cyan transition-colors">
                                    {acc.categorie}
                                </span>
                            </td>
                            <td class="p-8 text-right">
                                <div class="flex justify-end gap-3">
                                    <a href={`/admin/accessoires/modifier/${acc.id}`} class="w-10 h-10 flex items-center justify-center rounded-xl bg-slate-50 text-slate-400 hover:bg-stradip-blue hover:text-white transition-all">
                                        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z" /></svg>
                                    </a>
                                    <button 
                                        class="delete-btn w-10 h-10 flex items-center justify-center rounded-xl bg-slate-50 text-slate-400 hover:bg-red-500 hover:text-white transition-all"
                                        data-id={acc.id}
                                        data-nom={acc.nom}
                                    >
                                        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16" /></svg>
                                    </button>
                                </div>
                            </td>
                        </tr>
                    ))}
                </tbody>
            </table>
        </div>
    </div>

    <!-- MODAL DE CONFIRMATION -->
    <div id="deleteModal" class="fixed inset-0 z-50 flex items-center justify-center hidden p-4">
        <div class="absolute inset-0 bg-slate-900/40 backdrop-blur-sm" id="modalOverlay"></div>
        <div class="relative bg-white rounded-[2.5rem] shadow-2xl border border-slate-100 w-full max-w-md p-10 overflow-hidden transform transition-all scale-95 opacity-0 duration-300" id="modalContent">
            <div class="w-20 h-20 bg-red-50 text-red-500 rounded-3xl flex items-center justify-center mb-8 mx-auto">
                <svg class="w-10 h-10" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16" /></svg>
            </div>
            <div class="text-center space-y-4">
                <h3 class="text-2xl font-black text-slate-900 uppercase tracking-tighter italic">Confirmer la <span class="text-red-500">Suppression</span></h3>
                <p class="text-slate-500 text-sm leading-relaxed">Voulez-vous vraiment retirer <span id="deleteAccName" class="font-bold text-slate-900"></span> ?</p>
            </div>
            <div class="flex flex-col gap-3 mt-10">
                <button id="confirmDelete" class="w-full bg-red-500 text-white py-4 rounded-2xl text-[10px] font-black uppercase tracking-[3px] hover:bg-red-600 transition-all">Supprimer l'article</button>
                <button id="cancelDelete" class="w-full bg-slate-50 text-slate-400 py-4 rounded-2xl text-[10px] font-black uppercase tracking-[3px] hover:bg-slate-100 transition-all">Annuler</button>
            </div>
        </div>
    </div>
</AdminLayout>

<script>
    const deleteBtns = document.querySelectorAll('.delete-btn');
    const deleteModal = document.getElementById('deleteModal');
    const modalContent = document.getElementById('modalContent');
    const modalOverlay = document.getElementById('modalOverlay');
    const cancelBtn = document.getElementById('cancelDelete');
    const confirmBtn = document.getElementById('confirmDelete');
    const accNameSpan = document.getElementById('deleteAccName');

    let currentDeleteId = null;
    let currentRow = null;

    const openModal = (id, nom, row) => {
        currentDeleteId = id;
        currentRow = row;
        if (accNameSpan) accNameSpan.textContent = nom;
        deleteModal?.classList.remove('hidden');
        setTimeout(() => {
            modalContent?.classList.remove('scale-95', 'opacity-0');
            modalContent?.classList.add('scale-100', 'opacity-100');
        }, 10);
    };

    const closeModal = () => {
        modalContent?.classList.remove('scale-100', 'opacity-100');
        modalContent?.classList.add('scale-95', 'opacity-0');
        setTimeout(() => {
            deleteModal?.classList.add('hidden');
        }, 300);
    };

    deleteBtns.forEach(btn => {
        btn.addEventListener('click', () => {
            const id = btn.getAttribute('data-id');
            const nom = btn.getAttribute('data-nom');
            const row = btn.closest('tr');
            openModal(id, nom, row);
        });
    });

    [cancelBtn, modalOverlay].forEach(el => el?.addEventListener('click', closeModal));

    confirmBtn?.addEventListener('click', async () => {
        if (!currentDeleteId) return;
        try {
            const response = await fetch(`${import.meta.env.PUBLIC_API_URL}/api/accessories/${currentDeleteId}`, {
                method: 'DELETE'
            });
            if (response.ok) {
                currentRow?.remove();
                closeModal();
            }
        } catch (error) {
            console.error("Erreur:", error);
            alert("Erreur de connexion.");
        }
    });
</script>
