---
// src/pages/admin/projets/add-section.astro
import AdminLayout from '../../../layouts/AdminLayout.astro';

export const prerender = false;

const projectId = Astro.url.searchParams.get('project_id');

if (!projectId) {
    return Astro.redirect('/admin/projets');
}

// Récupération des détails du projet pour le contexte
let project: any = null;
let produits_db = [];

try {
    const projRes = await fetch(`${import.meta.env.PUBLIC_API_URL}/api/projects/${projectId}`);
    if (projRes.ok) project = await projRes.json();

    const prodRes = await fetch(`${import.meta.env.PUBLIC_API_URL}/api/products/`);
    if (prodRes.ok) {
        const prodData = await prodRes.json();
        produits_db = prodData.items || prodData;
    }
} catch (e) {
    console.error("Erreur de récupération", e);
}

if (!project) return Astro.redirect('/admin/projets');
---

<AdminLayout title="Ajouter une Pièce" currentPage="/admin/projets">
    <div class="max-w-4xl mx-auto">
        <div class="mb-12">
            <p class="text-stradip-cyan font-bold text-xs uppercase tracking-widest mb-2">Projet en cours : {project.nom}</p>
            <h2 class="text-3xl font-bold text-slate-900 uppercase tracking-tighter">Ajouter une pièce / section</h2>
        </div>

        <form id="sectionForm" class="bg-white p-5 sm:p-8 md:p-12 shadow-xl border border-slate-100 rounded-2xl sm:rounded-3xl grid grid-cols-1 md:grid-cols-2 gap-6 sm:gap-8">
            <div id="statusMessage" class="hidden md:col-span-2 p-4 rounded-xl text-sm font-bold"></div>

            <div class="md:col-span-2">
                <label class="block text-[0.65rem] font-black uppercase tracking-widest text-slate-400 mb-2">Titre de la pièce (ex: Salon de réception)</label>
                <input type="text" name="titre_piece" required class="w-full p-4 bg-slate-50 border border-slate-200 rounded-xl outline-none focus:border-stradip-cyan transition-colors font-bold text-slate-800">
            </div>

            <div class="md:col-span-2">
                <label class="block text-[0.65rem] font-black uppercase tracking-widest text-slate-400 mb-2">Description</label>
                <textarea name="description" rows="3" class="w-full p-4 bg-slate-50 border border-slate-200 rounded-xl outline-none focus:border-stradip-cyan transition-colors resize-none"></textarea>
            </div>

            <div class="md:col-span-2">
                <label class="block text-[0.65rem] font-black uppercase tracking-widest text-slate-400 mb-2">Photo d'ambiance (Principale)</label>
                
                <!-- PREVIEW CONTAINER -->
                <div id="ambiancePreviewContainer" class="hidden mb-4 relative rounded-2xl overflow-hidden aspect-video bg-slate-100 shadow-sm border border-slate-200">
                    <img id="ambiancePreview" src="#" class="w-full h-full object-cover" />
                    <button type="button" id="removeAmbianceBtn" class="absolute top-2 right-2 bg-red-500 text-white p-1.5 rounded-full hover:bg-red-600 transition-colors shadow-md">
                        <svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"></path></svg>
                    </button>
                </div>

                <div class="bg-slate-50/50 p-6 border-2 border-dashed border-slate-200 rounded-2xl" id="ambianceInputArea">
                    <input type="file" name="image_ambiance" id="ambianceInput" required accept="image/*" class="text-sm text-slate-500 file:mr-4 file:py-2 file:px-4 file:rounded-xl file:border-0 file:text-[0.6rem] file:font-black file:uppercase file:bg-stradip-blue file:text-white hover:file:bg-stradip-cyan file:transition-colors cursor-pointer">
                </div>
            </div>

            <div class="md:col-span-2 pt-6">
                <label class="block text-[0.65rem] font-black uppercase tracking-widest text-slate-400 mb-4">Galerie photos de la pièce</label>

                <div id="preview-container" class="grid grid-cols-2 md:grid-cols-4 lg:grid-cols-6 gap-4 mb-4">
                    <div id="addGalleryBtn" class="aspect-square border-2 border-dashed border-slate-200 rounded-xl flex flex-col items-center justify-center cursor-pointer hover:border-stradip-cyan hover:bg-stradip-cyan/5 transition-all group">
                        <span class="text-3xl text-slate-300 group-hover:text-stradip-cyan group-hover:scale-110 transition-transform">+</span>
                        <span class="text-[0.5rem] font-bold uppercase text-slate-400 mt-2 group-hover:text-stradip-cyan">Ajouter</span>
                    </div>
                </div>

                <input type="file" id="gallery-input" multiple class="hidden" accept="image/*">
            </div>

            <div class="md:col-span-2 pt-6 border-t border-slate-100">
                <label class="block text-[0.65rem] font-black uppercase tracking-widest text-slate-400 mb-4">Sélectionner les produits posés dans cette pièce :</label>
                <div class="grid grid-cols-1 sm:grid-cols-2 md:grid-cols-3 gap-3 max-h-48 overflow-y-auto p-4 sm:p-6 bg-slate-50 border border-slate-200 rounded-xl">
                    {produits_db.map((prod: any) => (
                        <label class="flex items-center space-x-3 cursor-pointer group">
                            <input type="checkbox" name="produit_ids" value={prod.id} class="w-4 h-4 accent-stradip-cyan rounded text-stradip-cyan focus:ring-stradip-cyan">
                            <span class="text-xs font-semibold text-slate-600 group-hover:text-stradip-blue">{prod.nom}</span>
                        </label>
                    ))}
                </div>
            </div>

            <div class="md:col-span-2 flex flex-col sm:flex-row gap-4 pt-6 border-t border-slate-100">
                <button type="submit" id="submitBtn" class="flex-1 bg-stradip-cyan text-white py-5 rounded-xl text-[0.7rem] font-black uppercase tracking-[3px] hover:bg-stradip-blue transition-all shadow-xl">
                    Enregistrer cette pièce
                </button>
                <a href={`/admin/projets/modifier/${projectId}`} class="flex-1 bg-slate-100 text-slate-600 text-center py-5 rounded-xl text-[0.7rem] font-black uppercase tracking-[3px] hover:bg-slate-200 transition-all">
                    Terminer le projet
                </a>
            </div>
        </form>
    </div>
</AdminLayout>

<script define:vars={{ projectId }}>
    const form = document.getElementById('sectionForm');
    const submitBtn = document.getElementById('submitBtn');
    const statusMessage = document.getElementById('statusMessage');
    const ambianceInput = document.getElementById('ambianceInput');
    const ambiancePreviewContainer = document.getElementById('ambiancePreviewContainer');
    const ambiancePreview = document.getElementById('ambiancePreview');
    const removeAmbianceBtn = document.getElementById('removeAmbianceBtn');
    const ambianceInputArea = document.getElementById('ambianceInputArea');
    
    const galleryInput = document.getElementById('gallery-input');
    const previewContainer = document.getElementById('preview-container');
    const addGalleryBtn = document.getElementById('addGalleryBtn');

    let galleryFiles = [];

    // --- LOGIQUE PHOTO AMBIANCE ---
    ambianceInput?.addEventListener('change', (e) => {
        const file = e.target.files?.[0];
        if (file) {
            const reader = new FileReader();
            reader.onload = (ev) => {
                if (ambiancePreview) ambiancePreview.src = ev.target.result;
                ambiancePreviewContainer?.classList.remove('hidden');
                ambianceInputArea?.classList.add('hidden');
            };
            reader.readAsDataURL(file);
        }
    });

    removeAmbianceBtn?.addEventListener('click', () => {
        if (ambianceInput) ambianceInput.value = '';
        ambiancePreviewContainer?.classList.add('hidden');
        ambianceInputArea?.classList.remove('hidden');
    });

    // --- LOGIQUE GALERIE ---
    addGalleryBtn?.addEventListener('click', () => {
        galleryInput?.click();
    });

    galleryInput?.addEventListener('change', (e) => {
        const files = Array.from(e.target.files || []);
        files.forEach(file => {
            galleryFiles.push(file);
            const reader = new FileReader();
            reader.onload = (event) => {
                const div = document.createElement('div');
                div.className = "relative aspect-square rounded-xl bg-slate-100 border border-slate-200 group overflow-hidden shadow-sm";
                div.innerHTML = `
                    <img src="${event.target.result}" class="w-full h-full object-cover">
                    <button type="button" class="absolute inset-0 bg-red-600/80 text-white opacity-0 group-hover:opacity-100 transition-opacity flex items-center justify-center text-[0.6rem] font-black uppercase tracking-widest remove-photo">
                        Supprimer
                    </button>
                `;
                div.querySelector('.remove-photo')?.addEventListener('click', (ev) => {
                    ev.stopPropagation();
                    galleryFiles = galleryFiles.filter(f => f !== file);
                    div.remove();
                });
                previewContainer?.insertBefore(div, addGalleryBtn);
            };
            reader.readAsDataURL(file);
        });
        if (galleryInput) galleryInput.value = ''; 
    });

    // --- SOUMISSION FORMULAIRE ---
    form?.addEventListener('submit', async (e) => {
        e.preventDefault();
        
        statusMessage.classList.add('hidden');
        statusMessage.className = 'md:col-span-2 p-4 rounded-xl text-sm font-bold';
        submitBtn.disabled = true;
        submitBtn.textContent = 'Enregistrement de la pièce...';

        try {
            if (!ambianceInput.files || !ambianceInput.files[0]) throw new Error("Photo d'ambiance requise.");
            
            const formDataAmbiance = new FormData();
            formDataAmbiance.append('file', ambianceInput.files[0]);
            
            const uploadAmbRes = await fetch(`${import.meta.env.PUBLIC_API_URL}/api/upload/`, { method: 'POST', body: formDataAmbiance });
            if (!uploadAmbRes.ok) throw new Error("Échec de l'upload de la photo d'ambiance.");
            const { url: ambianceUrl } = await uploadAmbRes.json();

            const galleryUrls = [];
            for (const file of galleryFiles) {
                const fd = new FormData();
                fd.append('file', file);
                const res = await fetch(`${import.meta.env.PUBLIC_API_URL}/api/upload/`, { method: 'POST', body: fd });
                if (res.ok) {
                    const { url } = await res.json();
                    galleryUrls.push(url);
                }
            }

            const formData = new FormData(form);
            const selectedProductIds = Array.from(document.querySelectorAll('input[name="produit_ids"]:checked')).map(el => parseInt(el.value));

            const sectionData = {
                titre_piece: formData.get('titre_piece'),
                description: formData.get('description'),
                image_ambiance: ambianceUrl,
                ordre_affichage: 0,
                produit_ids: selectedProductIds
            };

            const sectionRes = await fetch(`${import.meta.env.PUBLIC_API_URL}/api/projects/${projectId}/sections`, {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify(sectionData)
            });

            if (!sectionRes.ok) {
                const errorData = await sectionRes.json();
                throw new Error(errorData.detail?.[0]?.msg || JSON.stringify(errorData.detail) || "Erreur API");
            }
            const newSection = await sectionRes.json();

            for (const url of galleryUrls) {
                await fetch(`${import.meta.env.PUBLIC_API_URL}/api/projects/sections/${newSection.id}/photos`, {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ image_url: url, ordre: 0 })
                });
            }

            statusMessage.textContent = "Pièce \"" + sectionData.titre_piece + "\" ajoutée ! Vous pouvez en ajouter une autre.";
            statusMessage.classList.add('bg-green-50', 'text-green-600');
            statusMessage.classList.remove('hidden');

            form.reset();
            galleryFiles = [];
            const previews = previewContainer.querySelectorAll('.relative');
            previews.forEach(p => p.remove());
            
            // On remet aussi l'input photo d'ambiance à zéro
            ambiancePreviewContainer?.classList.add('hidden');
            ambianceInputArea?.classList.remove('hidden');
            
            submitBtn.disabled = false;
            submitBtn.textContent = 'Enregistrer une autre pièce';
            
            window.scrollTo({ top: 0, behavior: 'smooth' });

        } catch (err) {
            console.error(err);
            statusMessage.textContent = "Erreur : " + err.message;
            statusMessage.classList.add('bg-red-50', 'text-red-600');
            statusMessage.classList.remove('hidden');
            submitBtn.disabled = false;
            submitBtn.textContent = 'Enregistrer cette pièce';
        }
    });
</script>
