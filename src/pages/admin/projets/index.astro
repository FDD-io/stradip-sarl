---
// src/pages/admin/projets/index.astro
import AdminLayout from '../../../layouts/AdminLayout.astro';

// Récupération des projets depuis l'API FastAPI
const response = await fetch(`${import.meta.env.PUBLIC_API_URL}/api/projects/`);
const data = await response.json();
const rawProjets = data.items || data;

const projets = Array.isArray(rawProjets) ? rawProjets.map((p: any) => ({
    id: p.id,
    nom: p.nom,
    ville: p.ville,
    description: p.introduction || "Aucune introduction disponible.",
    image_globale: p.image_globale.startsWith('http') ? p.image_globale : `${import.meta.env.PUBLIC_API_URL}${p.image_globale}`
})) : [];
---

<AdminLayout title="Gérer les Réalisations" currentPage="/admin/projets">
    <div class="flex flex-col sm:flex-row justify-between items-start sm:items-end gap-6 mb-12">
        <div>
            <h2 class="text-3xl font-bold text-slate-900 uppercase tracking-tighter">Portfolio de Réalisations</h2>
            <p class="text-slate-500 text-sm mt-1">Gérez vos chantiers et projets d'exception.</p>
        </div>
        <a href="/admin/projets/add" class="bg-stradip-blue text-white px-6 py-3 rounded-xl text-[0.6rem] font-black uppercase tracking-widest hover:bg-stradip-cyan transition-colors shadow-lg w-full sm:w-auto text-center">
            + Ajouter un projet
        </a>
    </div>

    <div class="grid grid-cols-1 xl:grid-cols-2 gap-8">
        {projets.map((p) => (
            <div class="bg-white border border-slate-100 rounded-3xl flex flex-col sm:flex-row overflow-hidden group hover:shadow-2xl transition-all duration-500">
                <div class="w-full h-48 sm:h-auto sm:w-48 shrink-0 bg-slate-100 overflow-hidden">
                    <img src={p.image_globale} class="w-full h-full object-cover group-hover:scale-110 transition duration-700" alt={p.nom}>
                </div>

                <div class="p-6 sm:p-8 flex-1 flex flex-col justify-between gap-4">
                    <div>
                        <div class="flex justify-between items-start mb-2">
                            <span class="text-[0.55rem] font-black uppercase tracking-widest text-stradip-cyan bg-stradip-cyan/10 px-3 py-1 rounded-full">{p.ville}</span>
                            <div class="flex space-x-2">
                                <a href={`/admin/projets/modifier/${p.id}`} class="w-8 h-8 flex items-center justify-center rounded-lg bg-slate-50 text-slate-400 hover:bg-stradip-cyan/10 hover:text-stradip-cyan transition-colors">
                                    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z" /></svg>
                                </a>
                                <button 
                                    class="delete-btn w-8 h-8 flex items-center justify-center rounded-lg bg-slate-50 text-slate-400 hover:bg-red-50 hover:text-red-500 transition-colors"
                                    data-id={p.id}
                                    data-nom={p.nom}
                                >
                                    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16" /></svg>
                                </button>
                            </div>
                        </div>
                        <h3 class="text-xl font-bold text-slate-900 uppercase tracking-tighter mt-1">{p.nom}</h3>
                    </div>
                    <p class="text-[0.7rem] text-slate-500 italic line-clamp-2 mt-4 leading-relaxed border-l-2 border-slate-100 pl-3">{p.description}</p>
                </div>
            </div>
        ))}
    </div>

    <!-- MODAL DE CONFIRMATION -->
    <div id="deleteModal" class="fixed inset-0 z-50 flex items-center justify-center hidden p-4">
        <div class="absolute inset-0 bg-slate-900/40 backdrop-blur-sm" id="modalOverlay"></div>
        <div class="relative bg-white rounded-[2.5rem] shadow-2xl border border-slate-100 w-full max-w-md p-10 overflow-hidden transform transition-all scale-95 opacity-0 duration-300" id="modalContent">
            <div class="w-20 h-20 bg-red-50 text-red-500 rounded-3xl flex items-center justify-center mb-8 mx-auto">
                <svg class="w-10 h-10" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16" /></svg>
            </div>
            <div class="text-center space-y-4">
                <h3 class="text-2xl font-black text-slate-900 uppercase tracking-tighter italic">Supprimer le <span class="text-red-500">Projet</span></h3>
                <p class="text-slate-500 text-sm leading-relaxed">Voulez-vous vraiment retirer <span id="deleteProjName" class="font-bold text-slate-900"></span> ? Toutes les sections et photos seront perdues.</p>
            </div>
            <div class="flex flex-col gap-3 mt-10">
                <button id="confirmDelete" class="w-full bg-red-500 text-white py-4 rounded-2xl text-[10px] font-black uppercase tracking-[3px] hover:bg-red-600 transition-all">Supprimer définitivement</button>
                <button id="cancelDelete" class="w-full bg-slate-50 text-slate-400 py-4 rounded-2xl text-[10px] font-black uppercase tracking-[3px] hover:bg-slate-100 transition-all">Annuler</button>
            </div>
        </div>
    </div>
</AdminLayout>

<script>
    const deleteBtns = document.querySelectorAll('.delete-btn');
    const deleteModal = document.getElementById('deleteModal');
    const modalContent = document.getElementById('modalContent');
    const modalOverlay = document.getElementById('modalOverlay');
    const cancelBtn = document.getElementById('cancelDelete');
    const confirmBtn = document.getElementById('confirmDelete');
    const projNameSpan = document.getElementById('deleteProjName');

    let currentDeleteId = null;
    let currentCard = null;

    const openModal = (id, nom, card) => {
        currentDeleteId = id;
        currentCard = card;
        if (projNameSpan) projNameSpan.textContent = nom;
        deleteModal?.classList.remove('hidden');
        setTimeout(() => {
            modalContent?.classList.remove('scale-95', 'opacity-0');
            modalContent?.classList.add('scale-100', 'opacity-100');
        }, 10);
    };

    const closeModal = () => {
        modalContent?.classList.remove('scale-100', 'opacity-100');
        modalContent?.classList.add('scale-95', 'opacity-0');
        setTimeout(() => {
            deleteModal?.classList.add('hidden');
        }, 300);
    };

    deleteBtns.forEach(btn => {
        btn.addEventListener('click', () => {
            const id = btn.getAttribute('data-id');
            const nom = btn.getAttribute('data-nom');
            const card = btn.closest('.bg-white');
            openModal(id, nom, card);
        });
    });

    [cancelBtn, modalOverlay].forEach(el => el?.addEventListener('click', closeModal));

    confirmBtn?.addEventListener('click', async () => {
        if (!currentDeleteId) return;
        try {
            const response = await fetch(`${import.meta.env.PUBLIC_API_URL}/api/projects/${currentDeleteId}`, {
                method: 'DELETE'
            });
            if (response.ok) {
                currentCard?.remove();
                closeModal();
            }
        } catch (error) {
            console.error("Erreur:", error);
            alert("Erreur de connexion.");
        }
    });
</script>
