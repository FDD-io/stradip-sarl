---
// src/pages/admin/projets/modifier/[id].astro
import AdminLayout from '../../../../layouts/AdminLayout.astro';

export const prerender = false;

const { id } = Astro.params;

// 1. Récupération des données réelles
let project: any = null;
try {
    const response = await fetch(`${import.meta.env.PUBLIC_API_URL}/api/projects/${id}`);
    if (response.ok) {
        project = await response.json();
    }
} catch (e) {
    console.error("Erreur de récupération", e);
}

if (!project) return Astro.redirect('/admin/projets');

const displayImageUrl = project.image_globale.startsWith('http') 
    ? project.image_globale 
    : `${import.meta.env.PUBLIC_API_URL}${project.image_globale}`;
---

<AdminLayout title={`Modifier ${project.nom}`}>
    <div class="max-w-5xl mx-auto">
        <header class="mb-12">
            <a href="/admin/projets" class="text-stradip-cyan text-[10px] font-black uppercase tracking-[3px] flex items-center gap-2 transition-all">
                ← Retour aux réalisations
            </a>
            <h2 class="text-4xl font-black text-slate-900 uppercase tracking-tighter mt-6 italic">Gérer le projet <span class="text-stradip-blue">{project.nom}</span></h2>
        </header>

        <form id="projectForm" class="bg-white p-6 sm:p-10 md:p-16 rounded-2xl sm:rounded-[3rem] shadow-sm border border-slate-100 space-y-8 sm:space-y-10 mb-12 sm:mb-20">
            <div id="statusMessage" class="hidden p-4 rounded-xl text-sm font-bold"></div>
            <h3 class="text-xs font-black uppercase tracking-[4px] text-stradip-cyan border-b border-slate-50 pb-4">Configuration Générale</h3>
            
            <div class="grid grid-cols-1 md:grid-cols-2 gap-8 items-start">
                <div class="space-y-10">
                    <div>
                        <label class="block text-[10px] font-black uppercase tracking-[3px] text-slate-400 mb-4">Nom de la réalisation</label>
                        <input type="text" name="nom" value={project.nom} required class="w-full px-8 py-5 bg-slate-50 border border-slate-100 rounded-2xl focus:border-stradip-cyan outline-none transition-all font-black text-lg">
                    </div>
                    <div>
                        <label class="block text-[10px] font-black uppercase tracking-[3px] text-slate-400 mb-4">Ville / Localisation</label>
                        <input type="text" name="ville" value={project.ville} required class="w-full px-8 py-5 bg-slate-50 border border-slate-100 rounded-2xl focus:border-stradip-cyan outline-none transition-all font-bold text-slate-700">
                    </div>
                </div>

                <div class="space-y-4">
                    <label class="block text-[10px] font-black uppercase tracking-[3px] text-slate-400">Image de couverture</label>
                    <div class="relative rounded-[2rem] overflow-hidden group shadow-2xl aspect-video bg-slate-100">
                        <img id="previewCover" src={displayImageUrl} class="w-full h-full object-cover" />
                        <div class="absolute inset-0 bg-slate-900/60 opacity-0 group-hover:opacity-100 transition-all flex flex-col items-center justify-center cursor-pointer" id="changeCoverBtn">
                            <span class="text-3xl mb-2">🔄</span>
                            <span class="text-[10px] font-black uppercase tracking-widest text-white">Changer la couverture</span>
                            <input type="file" id="coverInput" class="hidden" accept="image/*">
                        </div>
                    </div>
                </div>

                <div class="md:col-span-2">
                    <label class="block text-[10px] font-black uppercase tracking-[3px] text-slate-400 mb-4">Introduction</label>
                    <textarea name="introduction" rows="3" class="w-full px-8 py-5 bg-slate-50 border border-slate-100 rounded-2xl focus:border-stradip-cyan outline-none transition-all font-medium text-slate-600">{project.introduction}</textarea>
                </div>
            </div>

            <button type="submit" id="submitBtn" class="w-full bg-[#0a1628] text-white py-6 rounded-2xl text-[11px] font-black uppercase tracking-[4px] hover:bg-stradip-blue transition-all duration-500 shadow-xl disabled:opacity-50">
                Enregistrer les modifications générales
            </button>
        </form>

        <!-- SECTIONS MANAGEMENT -->
        <div class="space-y-8 pb-20">
            <div class="flex flex-col sm:flex-row justify-between items-start sm:items-center gap-4">
                <h3 class="text-xl font-black uppercase tracking-tighter text-slate-900">Pièces & Espaces ({(project.sections || []).length})</h3>
                <a href={`/admin/projets/add-section?project_id=${project.id}`} class="px-6 py-3 bg-stradip-cyan text-white rounded-xl text-[9px] font-black uppercase tracking-widest hover:bg-stradip-blue transition-all shadow-lg shadow-stradip-cyan/20 w-full sm:w-auto text-center">
                    + Ajouter une pièce
                </a>
            </div>

            <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                {(project.sections || []).map((s: any) => (
                    <div class="bg-white p-5 sm:p-6 rounded-[2rem] border border-slate-100 flex flex-col sm:flex-row sm:items-center justify-between gap-4 group hover:shadow-xl transition-all duration-500">
                        <div class="flex items-center gap-6">
                            <div class="w-16 h-16 rounded-2xl overflow-hidden bg-slate-50">
                                <img src={s.image_ambiance.startsWith('http') ? s.image_ambiance : `${import.meta.env.PUBLIC_API_URL}${s.image_ambiance}`} class="w-full h-full object-cover group-hover:scale-110 transition-transform duration-500" />
                            </div>
                            <div>
                                <h4 class="text-sm font-black text-slate-900 uppercase tracking-tight">{s.titre_piece}</h4>
                                <p class="text-[9px] text-slate-400 uppercase font-bold tracking-widest mt-1">Section ID: #{s.id}</p>
                            </div>
                        </div>
                        <div class="flex gap-2">
                            <a href={`/admin/projets/modifier-section/${s.id}`} class="w-10 h-10 flex items-center justify-center rounded-xl bg-slate-50 text-slate-400 hover:bg-stradip-blue hover:text-white transition-all shadow-sm">
                                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z" /></svg>
                            </a>
                            <button 
                                class="delete-section-btn w-10 h-10 flex items-center justify-center rounded-xl bg-slate-50 text-slate-400 hover:bg-red-500 hover:text-white transition-all shadow-sm"
                                data-id={s.id}
                                data-nom={s.titre_piece}
                            >
                                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16" /></svg>
                            </button>
                        </div>
                    </div>
                ))}
            </div>
        </div>
    </div>

    <!-- MODAL DELETE SECTION -->
    <div id="deleteModal" class="fixed inset-0 z-50 flex items-center justify-center hidden p-4">
        <div class="absolute inset-0 bg-slate-900/40 backdrop-blur-sm" id="modalOverlay"></div>
        <div class="relative bg-white rounded-[2.5rem] shadow-2xl border border-slate-100 w-full max-w-md p-10 overflow-hidden transform transition-all scale-95 opacity-0 duration-300" id="modalContent">
            <div class="text-center space-y-4">
                <h3 class="text-2xl font-black text-slate-900 uppercase tracking-tighter italic">Supprimer cette <span class="text-red-500">Pièce</span> ?</h3>
                <p class="text-slate-500 text-sm">Voulez-vous vraiment retirer <span id="deleteSecName" class="font-bold"></span> du projet ?</p>
            </div>
            <div class="flex flex-col gap-3 mt-10">
                <button id="confirmDelete" class="w-full bg-red-500 text-white py-4 rounded-2xl text-[10px] font-black uppercase tracking-[3px] hover:bg-red-600 transition-all">Supprimer</button>
                <button id="cancelDelete" class="w-full bg-slate-50 text-slate-400 py-4 rounded-2xl text-[10px] font-black uppercase tracking-[3px] hover:bg-slate-100 transition-all">Annuler</button>
            </div>
        </div>
    </div>
</AdminLayout>

<script define:vars={{ projId: id, currentCover: project.image_globale }}>
    const form = document.getElementById('projectForm');
    const coverInput = document.getElementById('coverInput');
    const changeCoverBtn = document.getElementById('changeCoverBtn');
    const previewCover = document.getElementById('previewCover');
    const submitBtn = document.getElementById('submitBtn');
    const statusMessage = document.getElementById('statusMessage');

    changeCoverBtn?.addEventListener('click', () => coverInput?.click());

    coverInput?.addEventListener('change', (e) => {
        const file = e.target.files?.[0];
        if (file) {
            const reader = new FileReader();
            reader.onload = (ev) => { if (previewCover) previewCover.src = ev.target.result; };
            reader.readAsDataURL(file);
        }
    });

    form?.addEventListener('submit', async (e) => {
        e.preventDefault();
        statusMessage.classList.add('hidden');
        statusMessage.className = 'p-4 rounded-xl text-sm font-bold';
        submitBtn.disabled = true;
        submitBtn.textContent = 'Enregistrement...';

        try {
            let coverUrl = currentCover;
            if (coverInput.files?.[0]) {
                const fd = new FormData();
                fd.append('file', coverInput.files[0]);
                const upRes = await fetch(`${import.meta.env.PUBLIC_API_URL}/api/upload/`, { method: 'POST', body: fd });
                const { url } = await upRes.json();
                coverUrl = url;
            }

            const fd = new FormData(form);
            const data = {
                nom: fd.get('nom'),
                ville: fd.get('ville'),
                introduction: fd.get('introduction'),
                image_globale: coverUrl
            };

            const res = await fetch(`${import.meta.env.PUBLIC_API_URL}/api/projects/${projId}`, {
                method: 'PUT',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify(data)
            });

            if (!res.ok) throw new Error("Erreur de mise à jour");

            statusMessage.textContent = "Projet mis à jour !";
            statusMessage.classList.add('bg-green-50', 'text-green-600');
            statusMessage.classList.remove('hidden');
            setTimeout(() => window.location.reload(), 1000);

        } catch (err) {
            statusMessage.textContent = err.message;
            statusMessage.classList.add('bg-red-50', 'text-red-600');
            statusMessage.classList.remove('hidden');
            submitBtn.disabled = false;
        }
    });

    // Delete Section Logic
    const deleteBtns = document.querySelectorAll('.delete-section-btn');
    const modal = document.getElementById('deleteModal');
    const modalContent = document.getElementById('modalContent');
    const confirmDelete = document.getElementById('confirmDelete');
    const cancelDelete = document.getElementById('cancelDelete');
    const overlay = document.getElementById('modalOverlay');
    const secNameSpan = document.getElementById('deleteSecName');

    let currentSecId = null;
    let currentRow = null;

    deleteBtns.forEach(btn => {
        btn.addEventListener('click', () => {
            currentSecId = btn.getAttribute('data-id');
            currentRow = btn.closest('.group');
            if (secNameSpan) secNameSpan.textContent = btn.getAttribute('data-nom');
            modal?.classList.remove('hidden');
            setTimeout(() => {
                modalContent?.classList.remove('scale-95', 'opacity-0');
                modalContent?.classList.add('scale-100', 'opacity-100');
            }, 10);
        });
    });

    const closeM = () => {
        modalContent?.classList.remove('scale-100', 'opacity-100');
        modalContent?.classList.add('scale-95', 'opacity-0');
        setTimeout(() => modal?.classList.add('hidden'), 300);
    };

    [cancelDelete, overlay].forEach(el => el?.addEventListener('click', closeM));

    confirmDelete?.addEventListener('click', async () => {
        if (!currentSecId) return;
        try {
            const res = await fetch(`${import.meta.env.PUBLIC_API_URL}/api/projects/sections/${currentSecId}`, { method: 'DELETE' });
            if (res.ok) {
                currentRow?.remove();
                closeM();
            }
        } catch (e) { alert("Erreur de suppression"); }
    });
</script>
