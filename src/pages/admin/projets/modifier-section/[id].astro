---
// src/pages/admin/projets/modifier-section/[id].astro
import AdminLayout from '../../../../layouts/AdminLayout.astro';

export const prerender = false;

const { id } = Astro.params;

let section: any = null;
let produits: any[] = [];

try {
    const res = await fetch(`${import.meta.env.PUBLIC_API_URL}/api/projects/sections/${id}`);
    if (res.ok) section = await res.json();

    const prodRes = await fetch(`${import.meta.env.PUBLIC_API_URL}/api/products/`);
    if (prodRes.ok) produits = await prodRes.json();
} catch (e) {
    console.error("Erreur", e);
}

if (!section) return Astro.redirect('/admin/projets');

const displayAmbianceUrl = section.image_ambiance.startsWith('http') 
    ? section.image_ambiance 
    : `${import.meta.env.PUBLIC_API_URL}${section.image_ambiance}`;
---

<AdminLayout title={`Modifier ${section.titre_piece}`}>
    <div class="max-w-4xl mx-auto">
        <header class="mb-12">
            <a href={`/admin/projets/modifier/${section.realisation_id}`} class="text-stradip-cyan text-[10px] font-black uppercase tracking-[3px] flex items-center gap-2 transition-all">
                ← Retour au projet
            </a>
            <h2 class="text-4xl font-black text-slate-900 uppercase tracking-tighter mt-6 italic">Édition : <span class="text-stradip-blue">{section.titre_piece}</span></h2>
        </header>

        <form id="sectionForm" class="bg-white p-6 sm:p-10 md:p-16 rounded-2xl sm:rounded-[3rem] shadow-sm border border-slate-100 space-y-8 sm:space-y-12">
            <div id="statusMessage" class="hidden p-4 rounded-xl text-sm font-bold"></div>
            
            <div class="space-y-8">
                <div>
                    <label class="block text-[10px] font-black uppercase tracking-[3px] text-slate-400 mb-4">Nom de la pièce / zone</label>
                    <input type="text" name="titre_piece" value={section.titre_piece} required class="w-full px-8 py-5 bg-slate-50 border border-slate-100 rounded-2xl focus:border-stradip-cyan outline-none transition-all font-black text-lg">
                </div>

                <div>
                    <label class="block text-[10px] font-black uppercase tracking-[3px] text-slate-400 mb-4">Description de l'espace</label>
                    <textarea name="description" rows="4" class="w-full px-8 py-5 bg-slate-50 border border-slate-100 rounded-2xl focus:border-stradip-cyan outline-none transition-all font-medium">{section.description}</textarea>
                </div>
            </div>

            <div class="grid grid-cols-1 md:grid-cols-2 gap-12">
                <div class="space-y-6">
                    <label class="block text-[10px] font-black uppercase tracking-[3px] text-slate-400">Photo d'ambiance actuelle</label>
                    <div class="relative group rounded-2xl overflow-hidden shadow-lg aspect-video bg-slate-100">
                        <img id="previewAmb" src={displayAmbianceUrl} class="w-full h-full object-cover" />
                        <div class="absolute inset-0 bg-slate-900/40 opacity-0 group-hover:opacity-100 transition-all flex flex-col items-center justify-center cursor-pointer" id="changeAmbBtn">
                            <span class="text-2xl mb-2">🔄</span>
                            <span class="text-[9px] font-black uppercase text-white tracking-widest">Remplacer</span>
                            <input type="file" id="ambInput" class="hidden" accept="image/*">
                        </div>
                    </div>
                </div>

                <div class="space-y-6">
                    <label class="block text-[10px] font-black uppercase tracking-[3px] text-slate-400">Gérer la galerie ({section.photos.length})</label>
                    <div class="grid grid-cols-3 gap-4" id="galleryContainer">
                        {section.photos.map((p: any) => (
                            <div class="relative group aspect-square rounded-xl overflow-hidden shadow-sm border border-slate-100">
                                <img src={p.image_url.startsWith('http') ? p.image_url : `${import.meta.env.PUBLIC_API_URL}${p.image_url}`} class="w-full h-full object-cover" />
                                <button type="button" class="delete-photo-btn absolute top-2 right-2 w-6 h-6 bg-red-500 text-white rounded-full flex items-center justify-center text-xs opacity-0 group-hover:opacity-100 transition-opacity" data-id={p.id}>✕</button>
                            </div>
                        ))}
                        <div class="aspect-square bg-slate-50 border-2 border-dashed border-slate-100 rounded-xl flex flex-center items-center justify-center cursor-pointer hover:border-stradip-cyan transition-all group" id="addPhotoBtn">
                            <span class="text-2xl text-slate-300 group-hover:text-stradip-cyan">+</span>
                            <input type="file" id="newPhotoInput" class="hidden" accept="image/*">
                        </div>
                    </div>
                </div>
            </div>

            <div class="pt-8">
                <button type="submit" id="submitBtn" class="w-full bg-[#0a1628] text-white py-6 rounded-2xl text-[11px] font-black uppercase tracking-[4px] hover:bg-stradip-blue transition-all duration-500 shadow-xl disabled:opacity-50">
                    Mettre à jour cette pièce
                </button>
            </div>

        </form>
    </div>
</AdminLayout>

<script define:vars={{ secId: id, currentAmb: section.image_ambiance }}>
    const form = document.getElementById('sectionForm');
    const ambInput = document.getElementById('ambInput');
    const previewAmb = document.getElementById('previewAmb');
    const changeAmbBtn = document.getElementById('changeAmbBtn');
    const addPhotoBtn = document.getElementById('addPhotoBtn');
    const newPhotoInput = document.getElementById('newPhotoInput');
    const galleryContainer = document.getElementById('galleryContainer');
    const statusMessage = document.getElementById('statusMessage');
    const submitBtn = document.getElementById('submitBtn');

    changeAmbBtn?.addEventListener('click', () => ambInput?.click());
    ambInput?.addEventListener('change', (e) => {
        const file = e.target.files?.[0];
        if (file) {
            const reader = new FileReader();
            reader.onload = (ev) => { if (previewAmb) previewAmb.src = ev.target.result; };
            reader.readAsDataURL(file);
        }
    });

    // Add Photo to Gallery
    addPhotoBtn?.addEventListener('click', () => newPhotoInput?.click());
    newPhotoInput?.addEventListener('change', async (e) => {
        const file = e.target.files?.[0];
        if (!file) return;

        try {
            const fd = new FormData();
            fd.append('file', file);
            const upRes = await fetch(`${import.meta.env.PUBLIC_API_URL}/api/upload/`, { method: 'POST', body: fd });
            const { url } = await upRes.json();

            const photoRes = await fetch(`${import.meta.env.PUBLIC_API_URL}/api/projects/sections/${secId}/photos`, {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ image_url: url, ordre: 0 })
            });

            if (photoRes.ok) window.location.reload();
        } catch (err) { alert("Erreur d'ajout photo"); }
    });

    // Delete Photo from Gallery
    document.querySelectorAll('.delete-photo-btn').forEach(btn => {
        btn.addEventListener('click', async () => {
            const pid = btn.getAttribute('data-id');
            if (confirm("Supprimer cette photo ?")) {
                const res = await fetch(`${import.meta.env.PUBLIC_API_URL}/api/projects/photos/${pid}`, { method: 'DELETE' });
                if (res.ok) btn.closest('div')?.remove();
            }
        });
    });

    form?.addEventListener('submit', async (e) => {
        e.preventDefault();
        statusMessage.classList.add('hidden');
        statusMessage.className = 'p-4 rounded-xl text-sm font-bold';
        submitBtn.disabled = true;

        try {
            let ambUrl = currentAmb;
            if (ambInput.files?.[0]) {
                const fd = new FormData();
                fd.append('file', ambInput.files[0]);
                const upRes = await fetch(`${import.meta.env.PUBLIC_API_URL}/api/upload/`, { method: 'POST', body: fd });
                const { url } = await upRes.json();
                ambUrl = url;
            }

            const fd = new FormData(form);
            const data = {
                titre_piece: fd.get('titre_piece'),
                description: fd.get('description'),
                image_ambiance: ambUrl
            };

            const res = await fetch(`${import.meta.env.PUBLIC_API_URL}/api/projects/sections/${secId}`, {
                method: 'PUT',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify(data)
            });

            if (res.ok) {
                statusMessage.textContent = "Pièce mise à jour !";
                statusMessage.classList.add('bg-green-50', 'text-green-600');
                statusMessage.classList.remove('hidden');
                setTimeout(() => window.location.reload(), 1000);
            }
        } catch (err) {
            statusMessage.textContent = "Erreur de mise à jour";
            statusMessage.classList.add('bg-red-50', 'text-red-600');
            statusMessage.classList.remove('hidden');
            submitBtn.disabled = false;
        }
    });
</script>
